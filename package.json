{
  "name": "inkshot-engine",
  "version": "0.1.0",
  "description": "Data-oriented RPG game engine built with TypeScript and Pixi.js",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PukoDeveloper/inkshot-engine.git"
  },
  "keywords": ["game-engine", "rpg", "pixi.js", "typescript", "ecs"],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PukoDeveloper/inkshot-engine/issues"
  },
  "homepage": "https://github.com/PukoDeveloper/inkshot-engine#readme",
  "dependencies": {
    "pixi.js": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
