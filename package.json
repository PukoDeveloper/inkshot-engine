{
  "name": "@inkshot/engine",
  "version": "0.2.14",
  "description": "Data-oriented RPG game engine built with TypeScript and Pixi.js",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "THIRD_PARTY_LICENSES.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "generate-licenses": "node scripts/generate-licenses.js",
    "build:bundle": "node scripts/generate-licenses.js && rolldown -c rolldown.bundle.config.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PukoDeveloper/inkshot-engine.git"
  },
  "keywords": [
    "game-engine",
    "rpg",
    "pixi.js",
    "typescript",
    "ecs"
  ],
  "author": "PukoDeveloper",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PukoDeveloper/inkshot-engine/issues"
  },
  "homepage": "https://github.com/PukoDeveloper/inkshot-engine#readme",
  "dependencies": {
    "pixi.js": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "jsdom": "^29.0.2",
    "rolldown": "^1.0.0-rc.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
